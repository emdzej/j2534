{
  "name": "@emdzej/j2534-serial",
  "version": "0.1.0",
  "description": "Node.js CDC ACM serial transport for @emdzej/j2534-driver. Talks to the Tactrix OpenPort 2.0 via /dev/cu.usbmodem* (macOS) / /dev/ttyACM* (Linux) / COMx (Windows) — no sudo required.",
  "keywords": [
    "j2534",
    "passthru",
    "tactrix",
    "openport",
    "diagnostics",
    "serial",
    "serialport",
    "cdc-acm",
    "transport",
    "node",
    "typescript"
  ],
  "homepage": "https://github.com/emdzej/j2534#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emdzej/j2534.git",
    "directory": "packages/serial"
  },
  "bugs": {
    "url": "https://github.com/emdzej/j2534/issues"
  },
  "license": "MIT",
  "author": "Michał Jaskólski",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@emdzej/j2534-types": "workspace:*",
    "serialport": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
