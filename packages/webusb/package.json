{
  "name": "@emdzej/j2534-webusb",
  "version": "0.1.0",
  "description": "Browser WebUSB API transport for @emdzej/j2534-driver. Talks to the Tactrix OpenPort 2.0 directly from Chrome/Edge — no native dependencies, runs in any modern Chromium-based browser.",
  "keywords": [
    "j2534",
    "passthru",
    "tactrix",
    "openport",
    "diagnostics",
    "webusb",
    "browser",
    "transport",
    "typescript"
  ],
  "homepage": "https://github.com/emdzej/j2534#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emdzej/j2534.git",
    "directory": "packages/webusb"
  },
  "bugs": {
    "url": "https://github.com/emdzej/j2534/issues"
  },
  "license": "MIT",
  "author": "Michał Jaskólski",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "@emdzej/j2534-types": "workspace:*"
  },
  "devDependencies": {
    "@types/w3c-web-usb": "^1.0.14",
    "typescript": "^5.7.0"
  }
}
